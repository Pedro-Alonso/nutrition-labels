# Copie para .env e ajuste conforme o ambiente.
# Variáveis EXPO_PUBLIC_* são inlined no build — NUNCA guarde segredos aqui.

EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Logs de request/response da API. Não precisa setar aqui — o `yarn start:debug`
# liga automaticamente. Só tem efeito em dev (em release é sempre desligado).
# EXPO_PUBLIC_DEBUG_LOGS=1
